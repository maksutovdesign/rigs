{
  "extends": "@rigs/config/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": false,
    "declarationMap": false,
    "typeRoots": [
      "./node_modules/@types"
    ],
    "types": [
      "node",
      "react",
      "react-dom",
      "jest"
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@rigs/types": [
        "../../packages/types/src/index.ts"
      ],
      "@rigs/utils": [
        "../../packages/utils/src/index.ts"
      ]
    },
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
