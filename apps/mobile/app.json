{
  "expo": {
    "name": "Rigs",
    "slug": "rigs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rigs",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rigs.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Используется для поиска снаряжения рядом с тобой",
        "NSCameraUsageDescription": "Используется для фото при выдаче/возврате снаряжения",
        "NSPhotoLibraryUsageDescription": "Используется для загрузки фото объявлений"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "package": "com.rigs.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#16a34a"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#16a34a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
