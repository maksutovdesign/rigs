# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://rigs:rigs_pass@localhost:5432/rigs_db?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min32chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min32chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── S3 / Yandex Object Storage ───────────────────────────────────────────────
# For local MinIO: S3_ENDPOINT=http://localhost:9000  (path-style, no virtual hosting)
# For Yandex:      S3_ENDPOINT=https://storage.yandexcloud.net
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=rigs-media
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=ru-central1
# Public URL is derived automatically:
#   Yandex → https://<S3_BUCKET>.storage.yandexcloud.net/<key>
#   MinIO   → <S3_ENDPOINT>/<S3_BUCKET>/<key>

# ─── SMS (SMSC.ru) ────────────────────────────────────────────────────────────
# Leave blank to disable SMS in development (OTP will be logged to console)
SMS_LOGIN=your_smsc_login
SMS_PASSWORD=your_smsc_password
SMS_SENDER=RIGS

# ─── YooKassa ─────────────────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
# Webhook secret is set in YooKassa dashboard; leave blank to skip signature check
YOOKASSA_WEBHOOK_SECRET=

# ─── Firebase Admin SDK (FCM push notifications) ──────────────────────────────
# Paste the entire service-account JSON as a single-line string.
# Download from Firebase Console → Project Settings → Service Accounts.
# Example (minified): {"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Leave blank to disable push notifications.
FIREBASE_SERVICE_ACCOUNT=

# ─── Passport / KYC encryption ────────────────────────────────────────────────
# 32-byte hex key used to encrypt passport data at rest (AES-256).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASSPORT_DATA_KEY=change_me_32byte_hex_key_here_00000000

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── CORS ─────────────────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
