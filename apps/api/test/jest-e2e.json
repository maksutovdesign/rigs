{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "moduleNameMapper": {
    "@rigs/types": "<rootDir>/packages/types/src/index.ts",
    "@rigs/utils": "<rootDir>/packages/utils/src/index.ts"
  }
}
