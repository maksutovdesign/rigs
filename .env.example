# ─── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Public URL of the web frontend (used for CORS and payment return URLs)
WEB_URL=http://localhost:3000
# Public URL of the site (used in email/SMS links)
SITE_URL=http://localhost:3000
# Base URL of the API itself (used by mobile and web clients)
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Add ?connection_limit=N to control the Prisma connection pool size (default 5)
DATABASE_URL=postgresql://postgres:password@localhost:5432/rigs?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES=7d

# ─── YooKassa Payments ───────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
# Shared secret used to verify webhook HMAC signatures
YOOKASSA_WEBHOOK_SECRET=your_webhook_secret

# ─── S3 / Yandex Object Storage ──────────────────────────────────────────────
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=rigs-media

# ─── Elasticsearch ───────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── Firebase (FCM push notifications) ──────────────────────────────────────
# JSON string of your Firebase service account credentials
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── SMS (smsc.ru) ───────────────────────────────────────────────────────────
SMS_LOGIN=your_smsc_login
SMS_PASSWORD=your_smsc_password

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@rigs.ru

# ─── KYC / Passport data encryption ─────────────────────────────────────────
# 64-character hex string (32 bytes) — generate with: openssl rand -hex 32
PASSPORT_DATA_KEY=change_me_64_hex_chars_here_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
